# =============================================================================
# Smart Price - Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_DB=smartprice
POSTGRES_USER=smartprice
POSTGRES_PASSWORD=smartprice
DATABASE_URL=postgresql+asyncpg://smartprice:smartprice@postgres:5432/smartprice

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# BROWSERLESS (Headless Chrome for scraping)
# =============================================================================
# WebSocket endpoint for Playwright
PLAYWRIGHT_WS_ENDPOINT=ws://browserless:3000

# Enable browserless for scraping (set to 'false' to use httpx only)
USE_BROWSERLESS=true

# =============================================================================
# PROXY (Optional - for BrightData or similar)
# =============================================================================
# Uncomment and fill these if you have a proxy service
# BRIGHTDATA_USERNAME=brd-customer-hl_xxxxx-zone-residential
# BRIGHTDATA_PASSWORD=your_password_here
# BRIGHTDATA_HOST=brd.superproxy.io
# BRIGHTDATA_PORT=22225

# Or generic proxy URL
# PROXY_URL=http://user:pass@proxy.example.com:8080

# =============================================================================
# QDRANT (Vector Database)
# =============================================================================
QDRANT_URL=http://qdrant:6333

# =============================================================================
# CLICKHOUSE (Analytics)
# =============================================================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=smartprice

# =============================================================================
# API SETTINGS
# =============================================================================
# Secret key for JWT tokens
SECRET_KEY=your-secret-key-change-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# SCRAPING SETTINGS
# =============================================================================
# Rate limits (requests per second)
WB_RATE_LIMIT=0.5
OZON_RATE_LIMIT=0.3

# Default marketplace IDs
OZON_MARKETPLACE_ID=1
WB_MARKETPLACE_ID=2

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
