# ==================== Application ====================
APP_NAME=Smart Price
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ==================== Database ====================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=smartprice
POSTGRES_PASSWORD=smartprice_secret
POSTGRES_DB=smartprice
# Or set full URL directly:
# DATABASE_URL=postgresql+asyncpg://smartprice:smartprice_secret@localhost:5432/smartprice

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Celery ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== Qdrant ====================
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ==================== ClickHouse ====================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123

# ==================== API Keys ====================
ANTHROPIC_API_KEY=your-anthropic-key-here
FIRECRAWL_API_KEY=your-firecrawl-key-here

# ==================== Auth ====================
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==================== Scraping ====================
SCRAPING_CONCURRENCY=3
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
# PROXY_LIST=path/to/proxies.txt
